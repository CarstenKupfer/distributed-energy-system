<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="800.0" spacing="15.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="at.uastw.disysenergygui.EnergyController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Wichtig: Hier muss fx:id stehen, nicht id! -->
    <Label fx:id="communityUsedLabel" text="Community Pool: 0% used" />
    <Label fx:id="gridPortionLabel" text="Grid Portion: 0% used" />

    <Button onAction="#onRefreshClick" text="refresh" />

    <HBox alignment="CENTER" spacing="10.0">
        <Label text="Start" />
        <DatePicker fx:id="startDatePicker" />
        <ComboBox fx:id="startHourCombo" prefWidth="100.0" />
    </HBox>

    <HBox alignment="CENTER" spacing="10.0">
        <Label text="End" />
        <DatePicker fx:id="endDatePicker" />
        <ComboBox fx:id="endHourCombo" prefWidth="100.0" />
    </HBox>

    <Button onAction="#onShowDataClick" text="show data" />

    <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="timestampCol" prefWidth="150.0" text="Timestamp" />
            <TableColumn fx:id="producedCol" prefWidth="150.0" text="Community produced" />
            <TableColumn fx:id="usedCol" prefWidth="150.0" text="Community used" />
            <TableColumn fx:id="gridCol" prefWidth="150.0" text="Grid used" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>